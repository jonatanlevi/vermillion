# העתק לקובץ `.env` במקום הזה (באותה תיקייה) ומלא ערכים.
# הקובץ `.env` לא נכנס ל-Git (מופיע ב-.gitignore).

# Supabase → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Google OAuth (אם משתמשים בהתחברות Google דרך Supabase)
# Google Cloud Console → OAuth 2.0 Client IDs (Web)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# Ollama — כתובת נגישה מהדפדפן (מחשב מקומי / מנהרת Cloudflare וכו')
EXPO_PUBLIC_OLLAMA_BASE_URL=https://YOUR_TUNNEL_OR_HOST
